{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
		    "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {
            }
        },
        {
            "name": "Debug-Gimbal",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ROBOT_BOARD": "GIMBAL"
            }
        },
        {
            "name": "Debug-Chassis",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ROBOT_BOARD": "CHASSIS"
            }
        },
        {
            "name": "Release-Gimbal",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ROBOT_BOARD": "GIMBAL"
            }
        },
        {
            "name": "Release-Chassis",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ROBOT_BOARD": "CHASSIS"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug-Gimbal",
            "configurePreset": "Debug-Gimbal"
        },
        {
            "name": "Debug-Chassis",
            "configurePreset": "Debug-Chassis"
        },
        {
            "name": "Release-Gimbal",
            "configurePreset": "Release-Gimbal"
        },
        {
            "name": "Release-Chassis",
            "configurePreset": "Release-Chassis"
        }
    ]
}
